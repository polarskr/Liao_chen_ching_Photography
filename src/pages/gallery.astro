---
import Layout from '../layouts/Layout.astro';

const series2023 = [
	{ src: '/assets/images/main img/Church.webp', caption: "Grundtvig's church, Denmark" },
	{ src: '/assets/images/main img/Bay.webp', caption: 'The bay at Louisiana Museum, Denmark' },
	{ src: '/assets/images/main img/Building.webp', caption: 'Liverpool street, London' },
];

const happyland = [
	{ src: '/assets/images/gallery/1.webp', caption: '' },
	{ src: '/assets/images/gallery/2.webp', caption: '' },
	{ src: '/assets/images/gallery/3.webp', caption: '' },
	{ src: '/assets/images/gallery/4.webp', caption: '' },
	{ src: '/assets/images/gallery/5.webp', caption: '' },
	{ src: '/assets/images/gallery/6.webp', caption: '' },
	{ src: '/assets/images/gallery/7.webp', caption: '' },
	{ src: '/assets/images/gallery/8.webp', caption: '' },
];
---

<Layout title="Gallery | Liao ChenChing" description="Ralph Liao 的攝影作品集">
	<section class="gallery-section">
		<h2 class="section-title">Gallery</h2>

		<div class="gallery-tabs">
			<button class="tab active" data-filter="all">All</button>
			<button class="tab" data-filter="2023">2023</button>
			<button class="tab" data-filter="happyland">Lost in Happyland</button>
		</div>

		<div class="gallery-content">
			<!-- 2023 Series -->
			<div class="series" id="series-2023">
				<div class="series-layout">
					<div class="series-quote">
						<p>"In black and white you suggest; in color you state. Much can be implied by suggestion, but statement demands certainty... absolute certainty"</p>
						<span class="series-quote-author">Paul Outerbridge.</span>
					</div>
					<div class="series-photos">
						{series2023.map((img, i) => (
							<figure class="series-photo" onclick={`open2023At(${i})`}>
								<img src={img.src} alt={img.caption} loading="lazy" />
								<figcaption>{img.caption}</figcaption>
							</figure>
						))}
					</div>
				</div>
			</div>

			<!-- Lost in Happyland Series -->
			<div class="series" id="series-happyland">
				<div class="happyland-header">
					<h3 class="series-name">Lost in Happyland</h3>
				</div>
				<div class="happyland-grid">
					{happyland.map((img, i) => (
						<div class="gallery-item" onclick={`openHappylandAt(${i})`}>
							<img src={img.src} alt={img.caption || `Photo ${i + 1}`} loading="lazy" />
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- Lightbox -->
	<div class="lightbox" id="lightbox">
		<div class="lightbox-backdrop" onclick="closeLightbox()"></div>
		<button class="lightbox-close" onclick="closeLightbox()">&#x2715;</button>
		<button class="lightbox-nav lightbox-prev" id="lightbox-prev" onclick="navigateLightbox(-1)">&#8249;</button>
		<div class="lightbox-img-wrap">
			<img id="lightbox-img" src="" alt="" />
			<p id="lightbox-caption" class="lightbox-caption"></p>
		</div>
		<button class="lightbox-nav lightbox-next" id="lightbox-next" onclick="navigateLightbox(1)">&#8250;</button>
	</div>
</Layout>

<script is:inline>
	function initGallery() {
		// ── Lightbox state ──────────────────────────────────────
		let lbImages = [];
		let lbIndex  = 0;

		const lightbox   = document.getElementById('lightbox');
		const lbImg      = document.getElementById('lightbox-img');
		const lbCaption  = document.getElementById('lightbox-caption');
		const lbPrev     = document.getElementById('lightbox-prev');
		const lbNext     = document.getElementById('lightbox-next');

		function open2023At(index) {
			const items = document.querySelectorAll('.series-photo img');
			lbImages = Array.from(items).map(img => ({ src: img.src, alt: img.alt }));
			lbIndex  = index;
			_showLightbox();
		}

		function openHappylandAt(index) {
			const items = document.querySelectorAll('.gallery-item img');
			lbImages = Array.from(items).map(img => ({ src: img.src, alt: img.alt }));
			lbIndex  = index;
			_showLightbox();
		}

		function _showLightbox() {
			_setImage(lbImages[lbIndex].src, lbImages[lbIndex].alt, false);
			_updateNav();
			lightbox.classList.add('active');
			document.body.style.overflow = 'hidden';
		}

		function closeLightbox() {
			lightbox.classList.remove('active');
			document.body.style.overflow = '';
		}

		function navigateLightbox(dir) {
			const next = lbIndex + dir;
			if (next < 0 || next >= lbImages.length) return;
			lbIndex = next;
			_setImage(lbImages[lbIndex].src, lbImages[lbIndex].alt, true);
			_updateNav();
		}

		function _setImage(src, alt, animate) {
			if (animate) {
				lbImg.style.opacity = '0';
				lbImg.style.transform = 'scale(0.97)';
				setTimeout(() => {
					lbImg.src = src;
					lbImg.alt = alt;
					lbCaption.textContent = alt;
					lbImg.style.opacity = '1';
					lbImg.style.transform = 'scale(1)';
				}, 180);
			} else {
				lbImg.src = src;
				lbImg.alt = alt;
				lbCaption.textContent = alt;
				lbImg.style.opacity = '1';
				lbImg.style.transform = 'scale(1)';
			}
		}

		function _updateNav() {
			lbPrev.style.display = lbIndex > 0 ? 'flex' : 'none';
			lbNext.style.display = lbIndex < lbImages.length - 1 ? 'flex' : 'none';
		}

		window.open2023At       = open2023At;
		window.openHappylandAt  = openHappylandAt;
		window.closeLightbox    = closeLightbox;
		window.navigateLightbox = navigateLightbox;

		document.addEventListener('keydown', (e) => {
			if (!lightbox.classList.contains('active')) return;
			if (e.key === 'Escape')      closeLightbox();
			if (e.key === 'ArrowRight')  navigateLightbox(1);
			if (e.key === 'ArrowLeft')   navigateLightbox(-1);
		});

		// ── Tab transitions ─────────────────────────────────────
		const tabs   = document.querySelectorAll('.tab');
		const content = document.querySelector('.gallery-content');
		const s2023  = document.getElementById('series-2023');
		const sHappy = document.getElementById('series-happyland');

		function showFilter(filter) {
			content.style.opacity   = '0';
			content.style.transform = 'translateY(6px)';

			setTimeout(() => {
				s2023.style.display  = (filter === 'all' || filter === '2023')      ? 'block' : 'none';
				sHappy.style.display = (filter === 'all' || filter === 'happyland') ? 'block' : 'none';
				content.style.opacity   = '1';
				content.style.transform = 'translateY(0)';
			}, 220);
		}

		tabs.forEach(tab => {
			tab.addEventListener('click', () => {
				tabs.forEach(t => t.classList.remove('active'));
				tab.classList.add('active');
				showFilter(tab.dataset.filter);
			});
		});
	}

	document.addEventListener('astro:page-load', initGallery);
	if (document.readyState !== 'loading') initGallery();
</script>

<style>
	.gallery-section {
		padding: 2rem 0;
	}

	.section-title {
		font-family: 'Bodoni', serif;
		font-size: 2rem;
		font-weight: 300;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		margin-bottom: 2rem;
		text-align: center;
	}

	/* Tabs */
	.gallery-tabs {
		display: flex;
		justify-content: center;
		margin-bottom: 3rem;
		border-bottom: 1px solid #e0e0e0;
	}

	.tab {
		background: none;
		border: none;
		border-bottom: 2px solid transparent;
		padding: 0.6rem 1.8rem;
		font-family: 'Bodoni', serif;
		font-size: 0.85rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		cursor: pointer;
		color: #999;
		margin-bottom: -1px;
		transition: color 0.2s, border-color 0.2s;
	}

	.tab:hover { color: #333; }
	.tab.active { color: #111; border-bottom-color: #111; }

	/* Content fade wrapper */
	.gallery-content {
		transition: opacity 0.22s ease, transform 0.22s ease;
	}

	/* 2023 Series */
	.series {
		margin-bottom: 4rem;
	}

	.series-layout {
		display: flex;
		gap: 2rem;
		align-items: flex-start;
	}

	.series-quote {
		flex: 0 0 200px;
		font-family: 'Bodoni', serif;
		font-size: 0.95rem;
		line-height: 1.7;
		color: #333;
		padding-top: 1rem;
	}

	.series-quote-author {
		display: block;
		margin-top: 1rem;
		font-style: italic;
	}

	.series-photos {
		display: flex;
		gap: 1.5rem;
		flex: 1;
	}

	.series-photo {
		flex: 1;
		cursor: pointer;
		margin: 0;
	}

	.series-photo img {
		width: 100%;
		height: auto;
		display: block;
		transition: opacity 0.3s ease;
	}

	.series-photo:hover img { opacity: 0.85; }

	.series-photo figcaption {
		text-align: center;
		font-family: 'Courier New', monospace;
		font-size: 0.75rem;
		color: #666;
		margin-top: 0.8rem;
		line-height: 1.4;
	}

	/* Lost in Happyland */
	.happyland-header { margin-bottom: 1.5rem; }

	.series-name {
		font-family: 'Bodoni', serif;
		font-size: 1.3rem;
		font-weight: 300;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: #333;
		margin: 0;
	}

	.happyland-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 8px;
	}

	.gallery-item {
		overflow: hidden;
		aspect-ratio: 3 / 2;
		cursor: pointer;
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
		display: block;
	}

	.gallery-item:hover img { transform: scale(1.04); }

	/* Lightbox */
	.lightbox {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 1000;
		align-items: center;
		justify-content: center;
	}

	.lightbox.active { display: flex; }

	.lightbox-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.92);
	}

	.lightbox-img-wrap {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.8rem;
		max-width: 88vw;
		max-height: 90vh;
	}

	.lightbox-img-wrap img {
		max-width: 88vw;
		max-height: 82vh;
		object-fit: contain;
		transition: opacity 0.18s ease, transform 0.18s ease;
		display: block;
	}

	.lightbox-caption {
		color: rgba(255,255,255,0.6);
		font-family: 'Courier New', monospace;
		font-size: 0.75rem;
		letter-spacing: 0.05em;
		text-align: center;
		margin: 0;
		min-height: 1em;
	}

	.lightbox-close {
		position: absolute;
		top: 1.5rem;
		right: 1.5rem;
		z-index: 2;
		background: none;
		border: none;
		color: rgba(255,255,255,0.7);
		font-size: 1.8rem;
		cursor: pointer;
		transition: color 0.2s;
		line-height: 1;
	}

	.lightbox-close:hover { color: #fff; }

	.lightbox-nav {
		position: relative;
		z-index: 2;
		background: none;
		border: none;
		color: rgba(255,255,255,0.55);
		font-size: 3.5rem;
		cursor: pointer;
		padding: 1rem 1.2rem;
		line-height: 1;
		transition: color 0.2s;
		user-select: none;
		flex-shrink: 0;
	}

	.lightbox-nav:hover { color: #fff; }

	@media (max-width: 900px) {
		.series-layout { flex-direction: column; }
		.series-quote  { flex: none; }
	}

	@media (max-width: 720px) {
		.series-photos { flex-direction: column; }
		.happyland-grid { grid-template-columns: repeat(2, 1fr); }
		.lightbox-nav { font-size: 2.5rem; padding: 0.5rem 0.8rem; }
	}
</style>
