---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Liao ChenChing">
	<section class="contact-section">
		<h2 class="contact-title">Contact Me</h2>
		<div class="contact-form">
			<form action="https://formsubmit.co/38518874a@gmail.com" method="post">
				<input type="hidden" name="_redirect" value="https://ralphliao.xyz/thank-you/" />
				<input type="hidden" name="_subject" value="New submission from ralphliao.xyz!" />

				<div class="field">
					<label for="name">Name</label>
					<input type="text" id="name" name="name" required />
				</div>

				<div class="field">
					<label for="email">Email</label>
					<input type="email" id="email" name="email" required />
				</div>

				<div class="field">
					<label for="subject">Subject</label>
					<input type="text" id="subject" name="subject" required />
				</div>

				<div class="field">
					<label for="message">Message</label>
					<textarea id="message" name="message" rows="5" required></textarea>
				</div>

				<button type="submit">Send</button>
			</form>
		</div>
	</section>
</Layout>

<style>
	.contact-section {
		max-width: 560px;
		margin: 3rem auto;
		padding: 0 1rem;
	}

	.contact-title {
		font-family: 'Bodoni', serif;
		font-size: 2rem;
		font-weight: 300;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		text-align: center;
		margin-bottom: 2.5rem;
		color: #111;
	}

	.contact-form {
		width: 100%;
	}

	.field {
		margin-bottom: 1.4rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	label {
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #888;
	}

	input[type="text"],
	input[type="email"],
	textarea {
		width: 100%;
		padding: 0.7rem 0.9rem;
		border: 1px solid #ddd;
		border-radius: 2px;
		font-family: inherit;
		font-size: 0.95rem;
		color: #111;
		background: #fff;
		box-sizing: border-box;
		transition: border-color 0.2s;
		outline: none;
	}

	input:focus,
	textarea:focus {
		border-color: #111;
	}

	textarea {
		resize: vertical;
		min-height: 130px;
	}

	button {
		width: 100%;
		padding: 0.85rem;
		margin-top: 0.5rem;
		background: #111;
		color: #fff;
		border: none;
		border-radius: 2px;
		font-family: 'Bodoni', serif;
		font-size: 0.85rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		cursor: pointer;
		transition: background 0.2s;
	}

	button:hover {
		background: #333;
	}
</style>
