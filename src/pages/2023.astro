---
import Layout from '../layouts/Layout.astro';
---

<Layout title="2023 Gallery" mainClass="layout-photo-grid">
	<div class="intro-word">
		<!-- Note: inline SCSS variables like $font-mono don't work directly in standard HTML style attribute, we rely on the main stylesheet -->
		<p class="font-mono">"In black and white you suggest; in color you state. Much can be implied by suggestion, but statement demands certainty... absolute certainty" Paul Outerbridge.</p>
	</div>

	<figure class="photo-container">
		<img src="/assets/images/main img/Church.webp" alt="Church" loading="lazy" />
		<figcaption>Grundtvig's church, Denmark</figcaption>
	</figure>

	<figure class="photo-container">
		<img src="/assets/images/main img/Bay.webp" alt="Bay" loading="lazy" />
		<figcaption>The bay at Louisiana Museum, Denmark</figcaption>
	</figure>

	<figure class="photo-container">
		<img src="/assets/images/main img/Building.webp" alt="Building" loading="lazy" />
		<figcaption>Liverpool street, London</figcaption>
	</figure>
</Layout>
