---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You | Liao ChenChing" description="Message sent successfully.">
	<div class="thank-you">
		<h2>Thank you!</h2>
		<p>Your message has been received. I'll get back to you as soon as possible.</p>
		<a href="/">← Back to Home</a>
	</div>
</Layout>

<style>
	.thank-you {
		text-align: center;
		padding: 6rem 2rem;
	}

	.thank-you h2 {
		font-family: 'Bodoni', serif;
		font-size: 2.5rem;
		font-weight: 400;
		margin-bottom: 1rem;
	}

	.thank-you p {
		color: #666;
		margin-bottom: 2rem;
	}

	.thank-you a {
		color: inherit;
		text-decoration: underline;
		font-size: 0.9rem;
		letter-spacing: 0.05em;
	}
</style>
