---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort((a, b) => {
	const dateA = a.data.date || a.data.pubDate || new Date(0);
	const dateB = b.data.date || b.data.pubDate || new Date(0);
	return dateB.valueOf() - dateA.valueOf();
});

const allTags = [...new Set(posts.flatMap(p => p.data.categories || []))].sort();
---

<Layout title="Article | Liao ChenChing" description="Ralph Liao 的部落格文章列表">
	<section class="blog-list">
		<h2 class="section-title">Article</h2>

		<div class="tag-filter">
			<button class="tag-pill active" data-tag="all">All</button>
			{allTags.map(tag => (
				<button class="tag-pill" data-tag={tag}>{tag}</button>
			))}
		</div>

		<div class="blog-grid">
			{posts.map((post) => (
				<a href={`/blog/${post.id}/`} class="blog-card" data-tags={(post.data.categories || []).join(',')}>
					<div class="blog-card-image">
						{post.data.image ? (
							<img src={post.data.image} alt={post.data.title} loading="lazy" />
						) : (
							<div class="blog-card-placeholder">
								<span>{(post.data.categories || ['Article'])[0]}</span>
							</div>
						)}
					</div>
					<div class="blog-card-content">
						<div class="blog-card-meta">
							{(post.data.date || post.data.pubDate) && (
								<span class="meta-date">
									<FormattedDate date={post.data.date || post.data.pubDate || new Date()} />
								</span>
							)}
							{(post.data.categories || []).map((cat: string) => (
								<span class="meta-tag">{cat}</span>
							))}
						</div>
						<h3 class="blog-card-title">{post.data.title}</h3>
						{post.data.description && (
							<p class="blog-card-excerpt">{post.data.description}</p>
						)}
					</div>
				</a>
			))}
		</div>
	</section>
</Layout>

<script is:inline>
	document.addEventListener('astro:page-load', () => {
		const pills = document.querySelectorAll('.tag-pill');
		const cards = document.querySelectorAll('.blog-card');
		pills.forEach(pill => {
			pill.addEventListener('click', () => {
				pills.forEach(p => p.classList.remove('active'));
				pill.classList.add('active');
				const tag = pill.dataset.tag;
				cards.forEach(card => {
					const tags = card.dataset.tags ? card.dataset.tags.split(',') : [];
					card.style.display = (tag === 'all' || tags.includes(tag)) ? 'flex' : 'none';
				});
			});
		});
	});
</script>

<style>
	.blog-list { padding: 2rem 0; }

	.section-title {
		font-family: var(--font-display);
		font-size: 2rem;
		font-weight: 300;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		margin-bottom: 2rem;
		text-align: center;
	}

	.tag-filter {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		justify-content: center;
		margin-bottom: 2.5rem;
	}

	.tag-pill {
		background: none;
		border: 1px solid #ccc;
		border-radius: 999px;
		padding: 0.3rem 1rem;
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		cursor: pointer;
		color: #999;
		transition: all 0.2s ease;
	}

	.tag-pill:hover { color: #111; border-color: #111; }
	.tag-pill.active { background: #111; color: #fff; border-color: #111; }

	.blog-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
	}

	.blog-card {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
		border: 1px solid transparent;
		border-radius: 4px;
		overflow: hidden;
		transition: border-color 0.25s ease, transform 0.25s ease;
	}

	.blog-card:hover {
		border-color: rgba(0,0,0,0.1);
		transform: translateY(-3px);
	}

	.blog-card-image {
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
	}

	.blog-card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.blog-card:hover .blog-card-image img { transform: scale(1.04); }

	.blog-card-placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: #f0f0f0;
		font-size: 0.75rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: #999;
	}

	.blog-card-content {
		padding: 1.2rem 0.2rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.blog-card-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
	}

	.meta-date {
		font-size: 0.8rem;
		color: #999;
	}

	.meta-tag {
		font-size: 0.7rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #fff;
		background: #666;
		padding: 0.15rem 0.6rem;
		border-radius: 999px;
	}

	.blog-card-title {
		font-family: 'Bodoni', serif;
		font-size: 1.2rem;
		font-weight: 400;
		margin: 0;
		line-height: 1.35;
	}

	.blog-card-excerpt {
		font-size: 0.9rem;
		color: #666;
		line-height: 1.7;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	@media (max-width: 720px) {
		.blog-grid { grid-template-columns: 1fr; }
	}
</style>
