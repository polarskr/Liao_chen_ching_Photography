---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort((a, b) => {
	const dateA = a.data.date || a.data.pubDate || new Date(0);
	const dateB = b.data.date || b.data.pubDate || new Date(0);
	return dateB.valueOf() - dateA.valueOf();
});
---

<Layout title="Article | Liao ChenChing" description="Ralph Liao 的部落格文章列表">
	<section class="blog-list">
		<h2 class="section-title">Article</h2>
		<div class="blog-grid">
			{
				posts.map((post) => (
					<a href={`/blog/${post.id}/`} class="blog-card">
						{post.data.image && (
							<div class="blog-card-image">
								<img src={post.data.image} alt={post.data.title} loading="lazy" />
							</div>
						)}
						<div class="blog-card-content">
							<h3 class="blog-card-title">{post.data.title}</h3>
							<div class="blog-card-meta">
								{ (post.data.date || post.data.pubDate) && (
									<span class="blog-card-date">
										<FormattedDate date={post.data.date || post.data.pubDate || new Date()} />
									</span>
								)}
								{ post.data.categories && (
									<span class="blog-card-categories">
										{Array.isArray(post.data.categories) 
											? post.data.categories.join(' / ') 
											: post.data.categories}
									</span>
								)}
							</div>
							{post.data.description && (
								<p class="blog-card-excerpt">{post.data.description}</p>
							)}
						</div>
					</a>
				))
			}
		</div>
	</section>
</Layout>

<style>
	.blog-list {
		padding: 2rem 0;
	}

	.section-title {
		font-family: 'Bodoni', serif;
		font-size: 2rem;
		font-weight: 300;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		margin-bottom: 2.5rem;
		text-align: center;
	}

	.blog-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	.blog-card {
		display: flex;
		flex-direction: row;
		text-decoration: none;
		color: inherit;
		border-bottom: 1px solid rgba(0, 0, 0, 0.08);
		padding-bottom: 2rem;
		transition: opacity 0.3s ease;
	}

	.blog-card:hover {
		opacity: 0.7;
	}

	.blog-card-image {
		flex-shrink: 0;
		width: 220px;
		height: 150px;
		overflow: hidden;
		margin-right: 2rem;
	}

	.blog-card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.blog-card:hover .blog-card-image img {
		transform: scale(1.03);
	}

	.blog-card-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.blog-card-title {
		font-family: 'Bodoni', serif;
		font-size: 1.4rem;
		font-weight: 400;
		margin: 0 0 0.6rem 0;
		line-height: 1.3;
	}

	.blog-card-meta {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-size: 0.8rem;
		letter-spacing: 0.05em;
		color: #888;
		margin-bottom: 0.5rem;
	}

	.blog-card-categories {
		text-transform: uppercase;
		font-size: 0.75rem;
		letter-spacing: 0.1em;
	}

	.blog-card-excerpt {
		font-size: 0.9rem;
		color: #666;
		line-height: 1.6;
		margin: 0;
	}

	@media (max-width: 720px) {
		.blog-card {
			flex-direction: column;
		}

		.blog-card-image {
			width: 100%;
			height: 200px;
			margin-right: 0;
			margin-bottom: 1rem;
		}

		.blog-card-title {
			font-size: 1.2rem;
		}
	}
</style>
