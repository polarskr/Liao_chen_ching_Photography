---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Layout from './Layout.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, date, updatedDate, heroImage, image } = Astro.props;
const coverImage = image || heroImage;
---

<Layout title={`${title} | Liao ChenChing`} description={description}>
	<article class="blog-post">
		{coverImage && (
			<div class="hero-image">
				<img src={coverImage} alt={title} loading="lazy" />
			</div>
		)}
		<div class="prose">
			<div class="post-header">
				<div class="post-date">
					{ (date || pubDate) ? <FormattedDate date={date || pubDate} /> : null }
					{
						updatedDate && (
							<div class="last-updated-on">
								Last updated on <FormattedDate date={updatedDate} />
							</div>
						)
					}
				</div>
				<h1 class="post-title">{title}</h1>
				<hr />
			</div>
			<div class="post-content">
				<slot />
			</div>
		</div>
	</article>
</Layout>

<style>
	.blog-post {
		padding: 1rem 0;
	}

	.hero-image {
		width: 100%;
		margin-bottom: 2rem;
	}

	.hero-image img {
		display: block;
		width: 100%;
		max-height: 480px;
		object-fit: cover;
		border-radius: 4px;
	}

	.prose {
		max-width: 720px;
		margin: 0 auto;
	}

	.post-header {
		margin-bottom: 2rem;
		text-align: center;
	}

	.post-title {
		font-family: 'Bodoni', serif;
		font-size: 2rem;
		font-weight: 400;
		line-height: 1.3;
		margin: 0 0 0.5em 0;
	}

	.post-date {
		font-size: 0.85rem;
		color: #888;
		letter-spacing: 0.05em;
		margin-bottom: 0.8rem;
	}

	.last-updated-on {
		font-style: italic;
	}

	.post-header hr {
		border: none;
		border-top: 1px solid rgba(0, 0, 0, 0.1);
		margin-top: 1.5rem;
	}

	.post-content {
		font-size: 1rem;
		line-height: 1.8;
		color: #333;
	}

	.post-content :global(h2) {
		font-family: 'Bodoni', serif;
		font-size: 1.5rem;
		font-weight: 400;
		margin: 2.5rem 0 1rem;
		padding-bottom: 0.4rem;
		border-bottom: 1px solid rgba(0,0,0,0.08);
	}

	.post-content :global(h3) {
		font-family: 'Bodoni', serif;
		font-size: 1.25rem;
		font-weight: 400;
		margin: 2.5rem 0 1rem;
		padding-bottom: 0.4rem;
		border-bottom: 1px solid rgba(0,0,0,0.08);
		letter-spacing: 0.02em;
	}

	.post-content :global(p) {
		margin: 0 0 1.2rem;
	}

	.post-content :global(ol),
	.post-content :global(ul) {
		padding-left: 1.4rem;
		margin: 0 0 1.5rem;
	}

	.post-content :global(li) {
		margin-bottom: 1.8rem;
		line-height: 1.7;
	}

	.post-content :global(li > img) {
		display: block;
		max-width: 220px;
		height: auto;
		border-radius: 4px;
		margin: 0.8rem 0 0;
		border: 1px solid rgba(0,0,0,0.06);
	}

	.post-content :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 4px;
		margin: 1.5rem 0;
		display: block;
	}

	.post-content :global(blockquote) {
		border-left: 3px solid #ddd;
		padding-left: 1rem;
		margin: 1.5rem 0;
		color: #666;
		font-style: italic;
	}

	.post-content :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 1.5rem 0;
		font-size: 0.9rem;
	}

	.post-content :global(th),
	.post-content :global(td) {
		border: 1px solid #e0e0e0;
		padding: 0.7rem 1rem;
		text-align: left;
		line-height: 1.5;
	}

	.post-content :global(th) {
		background: #f8f8f8;
		font-weight: 600;
		font-size: 0.85rem;
		letter-spacing: 0.03em;
	}

	.post-content :global(tr:nth-child(even) td) {
		background: #fafafa;
	}

	.post-content :global(hr) {
		border: none;
		border-top: 1px solid rgba(0,0,0,0.1);
		margin: 2.5rem 0;
	}

	@media (max-width: 720px) {
		.post-title {
			font-size: 1.5rem;
		}
	}
</style>
